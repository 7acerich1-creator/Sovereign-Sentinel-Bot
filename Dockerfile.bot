# Gravity Claw v3.0 — Multi-stage build
FROM node:20-slim AS builder

WORKDIR /app

# Install build deps for native modules (better-sqlite3)
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json* ./
RUN npm ci || npm install
COPY tsconfig.json ./
COPY src/ ./src/
RUN ./node_modules/.bin/tsc

# ── Production Stage ──
FROM node:20-slim

# Python for Maven Crew + ffmpeg for sovereign clip pipeline + native module runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy build artifacts + prod deps
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev || npm install --omit=dev
COPY --from=builder /app/dist ./dist

# Copy identity, config, and support files
COPY soul.md ./soul.md
COPY claude.md ./claude.md
COPY maven_crew ./maven_crew
COPY skills ./skills

# Install Python deps for Maven Crew + sovereign clip pipeline
RUN pip3 install --no-cache-dir --break-system-packages \
    crewai \
    python-dotenv \
    requests \
    langchain-google-genai \
    langchain-openai \
    langchain-anthropic \
    yt-dlp \
    openai-whisper

# Create persistent data directories
RUN mkdir -p /app/data /app/memory /app/.agent/logs

# Health check
HEALTHCHECK --interval=60s --timeout=10s --start-period=60s \
    CMD node -e "const http=require('http');const r=http.get('http://localhost:3000/health',res=>{process.exit(res.statusCode===200?0:1)});r.on('error',()=>process.exit(1));r.setTimeout(5000,()=>{r.destroy();process.exit(1)})" || exit 1

ENV MAVEN_CREW_PATH=./maven_crew
ENV NODE_ENV=production
ENV SQLITE_PATH=/app/data/gravity-claw.db

EXPOSE 3000

CMD ["node", "dist/index.js"]
