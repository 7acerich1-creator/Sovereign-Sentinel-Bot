# Gravity Claw v3.0 — Multi-stage build

# ── Static ffmpeg stage ──
# COPY-from approach avoids the 200+ transitive .deb unpack that blows Railway
# builder memory (exit 137 OOM) when apt-installing ffmpeg on node:20-slim.
FROM mwader/static-ffmpeg:7.0 AS ffmpeg

# ── Builder stage ──
FROM node:20-slim AS builder

WORKDIR /app

# Install build deps for native modules (better-sqlite3)
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json* ./
RUN npm ci || npm install
COPY tsconfig.json ./
COPY src/ ./src/
RUN ./node_modules/.bin/tsc && cp src/data/*.json dist/data/

# ── Production Stage ──
# nikolaik/python-nodejs ships Node 20 + Python 3.11 + pip preinstalled, which
# eliminates the python3 apt-install layer that was OOM-killing Railway's builder
# (exit 137). Only chromium remains as an apt install.
FROM nikolaik/python-nodejs:python3.11-nodejs20-slim

# S126 (2026-04-30) — Chromium ACTUALLY installed now, not just gestured at.
# Previously the Dockerfile set PUPPETEER_EXECUTABLE_PATH to a path that
# didn't exist (/usr/bin/chromium) — browser automation was silently broken
# for IG/TT/Threads uploads + Yuki TT reply worker. Fix: install chromium
# in production stage via apt with the minimal-deps flag to avoid the
# Singapore builder OOM that killed prior attempts. If this still OOMs,
# fall back to copying chrome from the builder stage via @puppeteer/browsers.
RUN apt-get update && apt-get install -y --no-install-recommends \
      chromium \
      fonts-liberation \
      ca-certificates \
      libnss3 \
      libxss1 \
      libasound2 \
      libatk-bridge2.0-0 \
      libgtk-3-0 \
    && rm -rf /var/lib/apt/lists/*

# Static ffmpeg + ffprobe binaries from the mwader stage (avoids apt OOM)
COPY --from=ffmpeg /ffmpeg /usr/local/bin/ffmpeg
COPY --from=ffmpeg /ffprobe /usr/local/bin/ffprobe

WORKDIR /app

# Copy build artifacts + prod deps
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev || npm install --omit=dev
COPY --from=builder /app/dist ./dist

# Copy identity, config, and support files
COPY soul.md ./soul.md
COPY claude.md ./claude.md
COPY skills ./skills

# Brand assets (intro/outro videos, audio signatures, Bebas Neue font)
COPY brand-assets ./brand-assets

# Install Python deps for sovereign clip pipeline
# yt-dlp: video download for Whisper extraction
# edge-tts: FREE Microsoft neural TTS (replaced unreliable edge-tts-node WebSocket library)
RUN pip3 install --no-cache-dir --break-system-packages yt-dlp edge-tts

# Configure yt-dlp globally: JS runtime + anti-bot-detection defaults
# YouTube 2025+ requires JS runtime for sig decryption + blocks datacenter IPs
RUN mkdir -p /etc/yt-dlp && printf '%s\n' \
  '--js-runtimes node' \
  '--remote-components ejs:github' \
  '--no-check-certificates' \
  '--extractor-retries 3' \
  > /etc/yt-dlp/config

# Create persistent data directories
RUN mkdir -p /app/data /app/memory /app/.agent/logs

# Health check
HEALTHCHECK --interval=60s --timeout=10s --start-period=60s \
    CMD node -e "const http=require('http');const r=http.get('http://localhost:3000/health',res=>{process.exit(res.statusCode===200?0:1)});r.on('error',()=>process.exit(1));r.setTimeout(5000,()=>{r.destroy();process.exit(1)})" || exit 1

ENV NODE_ENV=production
ENV SQLITE_PATH=/app/data/gravity-claw.db
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PUPPETEER_SKIP_DOWNLOAD=true

EXPOSE 3000

CMD ["node", "dist/index.js"]
