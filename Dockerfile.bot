# Gravity Claw v3.0 — Multi-stage build
FROM node:20-slim AS builder

WORKDIR /app

# Install build deps for native modules (better-sqlite3)
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json* ./
RUN npm ci || npm install
COPY tsconfig.json ./
COPY src/ ./src/
RUN ./node_modules/.bin/tsc && cp -r src/data dist/data

# ── Production Stage ──
FROM node:20-slim

# ffmpeg for sovereign clip pipeline + Python for yt-dlp/whisper + Chromium for browser automation
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip \
    ffmpeg \
    chromium \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy build artifacts + prod deps
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev || npm install --omit=dev
COPY --from=builder /app/dist ./dist

# Copy identity, config, and support files
COPY soul.md ./soul.md
COPY claude.md ./claude.md
COPY skills ./skills

# Install Python deps for sovereign clip pipeline (yt-dlp only — whisper uses OpenAI API)
RUN pip3 install --no-cache-dir --break-system-packages yt-dlp

# Configure yt-dlp globally: JS runtime + anti-bot-detection defaults
# YouTube 2025+ requires JS runtime for sig decryption + blocks datacenter IPs
RUN mkdir -p /etc/yt-dlp && printf '%s\n' \
  '--js-runtimes node' \
  '--remote-components ejs:github' \
  '--no-check-certificates' \
  '--extractor-retries 3' \
  > /etc/yt-dlp/config

# Create persistent data directories
RUN mkdir -p /app/data /app/memory /app/.agent/logs

# Health check
HEALTHCHECK --interval=60s --timeout=10s --start-period=60s \
    CMD node -e "const http=require('http');const r=http.get('http://localhost:3000/health',res=>{process.exit(res.statusCode===200?0:1)});r.on('error',()=>process.exit(1));r.setTimeout(5000,()=>{r.destroy();process.exit(1)})" || exit 1

ENV NODE_ENV=production
ENV SQLITE_PATH=/app/data/gravity-claw.db
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PUPPETEER_SKIP_DOWNLOAD=true

EXPOSE 3000

CMD ["node", "dist/index.js"]
